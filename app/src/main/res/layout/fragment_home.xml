<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- ── TOP BAR ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back 👋"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Find your next book"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sell"
                style="@style/Widget.Booki.Button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="+ Sell"
                android:textSize="13sp"
                android:paddingHorizontal="18dp"
                app:cornerRadius="20dp" />
        </LinearLayout>

        <!-- ── BANNER SLIDER ── -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/examPager"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp" />

        <!-- ── CATEGORIES LABEL ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORIES"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="12dp" />

        <!-- ── CATEGORY CHIPS ── -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="8dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <com.google.android.material.chip.ChipGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="4dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_jee"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:text="JEE"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/bg_elevated"
                    app:checkedIconVisible="false"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_neet"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:text="NEET"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/bg_elevated"
                    app:checkedIconVisible="false"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_upsc"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:text="UPSC"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/bg_elevated"
                    app:checkedIconVisible="false"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- ── BOOKS LABEL ── -->
        <TextView
            android:id="@+id/tvSelectedCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="JEE Books"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="12dp" />

        <!-- ── BOOKS RECYCLERVIEW ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/bookslistRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never" />

    </LinearLayout>
</ScrollView>